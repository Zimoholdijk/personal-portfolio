---
import SiteLayout from '../layouts/SiteLayout.astro';
import { SITE } from '../config';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<SiteLayout title={`Page not found · ${SITE.name}`} description="This page does not exist.">
  <section class="endcta pagetop">
    <div class="wrap">
      <span class="hand-k">well, this is awkward</span>
      <h2>404.</h2>
      <div class="row">
        <a class="cta" href={`${base}/`}>Head back home →</a>
        <a class="ghost" href={`${base}/projects/`}>See the projects</a>
      </div>
    </div>
  </section>
</SiteLayout>
