---
import SiteLayout from '../layouts/SiteLayout.astro';
import { SITE } from '../config';
import { projects } from '../data/projects';
import { toWorkCards } from '../lib/work';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const work = toWorkCards(projects, base);

// ItemList schema helps search engines understand this is a portfolio listing.
const listSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: work.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: p.title,
    url: new URL(p.href, Astro.site).toString(),
  })),
};
---

<SiteLayout
  title={`Projects · ${SITE.name}`}
  description={`Selected work by ${SITE.name}: AI-powered products for clients, family, and community.`}
  schema={listSchema}
>
  <section class="section pagetop">
    <div class="wrap">
      <div class="shead reveal"><h2>All projects</h2><span class="hand">problem → shipped ↓</span></div>
      <p class="lede reveal">
        Everything I've built, from agentic internal tools to marketplaces and
        RAG search. Tap any project for the full write-up.
      </p>
      <div class="works">
        {work.map((p) => (
          <a class="work reveal" href={p.href} style={`--c:${p.color};`}>
            <div class="work__media"><span>{p.media}</span></div>
            <div class="work__body">
              <span class="work__name">{p.title}</span>
              <span class="work__for">{p.forText}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</SiteLayout>
