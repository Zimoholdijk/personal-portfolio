---
import SiteLayout from '../layouts/SiteLayout.astro';
import { SITE } from '../config';
import { projects } from '../data/projects';
import { toWorkRows } from '../lib/work';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const rows = toWorkRows(projects, base);

// ItemList schema helps search engines understand this is a portfolio listing.
const listSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: rows.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: p.title,
    url: new URL(p.href, Astro.site).toString(),
  })),
};
---

<SiteLayout
  title={`Projects · ${SITE.name}`}
  description={`Selected work by ${SITE.name}: AI-powered products for clients, family, and community.`}
  schema={listSchema}
>
  <section class="section pagetop">
    <div class="wrap">
      <div class="shead reveal"><h2>All <span class="it">projects</span></h2><span class="lbl">{String(projects.length).padStart(2, '0')} builds</span></div>
      <p class="lede reveal">
        Everything I've built, from agentic internal tools to marketplaces and
        RAG search. Select any project for the full write-up.
      </p>
      <div class="cases">
        {rows.map((p) => (
          <a class="case reveal" href={p.href} style={`--c:${p.color};`}>
            <span class="case__no">{p.no}</span>
            <span class="case__name">{p.name}</span>
            <span class="case__desc">{p.blurb}</span>
            <span class="case__meta"><span class="case__thumb"></span><span class="tag">{p.audience}</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>
</SiteLayout>
