---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { SITE } from '../../config';
import { projects, type Project } from '../../data/projects';
import { cardColor } from '../../lib/work';

export function getStaticPaths() {
  return projects.map((project, index) => ({
    params: { slug: project.slug },
    props: { project, color: cardColor(index) },
  }));
}

interface Props {
  project: Project;
  color: string;
}

const { project, color } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const projectsUrl = `${base}/projects/`;

let host = '';
if (project.url) {
  try { host = new URL(project.url).hostname.replace(/^www\./, ''); } catch { host = 'the live site'; }
}

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: project.title,
  description: project.description,
  keywords: project.tags.join(', '),
  author: { '@type': 'Person', name: SITE.name },
  ...(project.url ? { url: project.url } : {}),
};
---

<SiteLayout
  title={`${project.title} · ${SITE.name}`}
  description={project.description.slice(0, 155)}
  schema={schema}
>
  <article class="section pagetop detail" style={`--c:${color};`}>
    <div class="wrap">
      <div class="inner">
        <a class="back reveal" href={projectsUrl}>← All projects</a>
        <div class="detail__banner reveal"></div>
        <div class="detail__tags reveal">
          {project.tags.map((t) => <span class="detail__tag">{t}</span>)}
        </div>
        <h1 class="reveal">{project.title}</h1>
        <p class="detail__lead reveal" data-d="1">{project.description}</p>
        <div class="detail__actions reveal" data-d="2">
          {project.url && <a class="cta" href={project.url} target="_blank" rel="noopener">Visit {host} →</a>}
          {project.repo && <a class="ghost" href={project.repo} target="_blank" rel="noopener">Source code</a>}
          <a class="ghost" href={`mailto:${SITE.email}`}>Ask me about it</a>
        </div>
      </div>
    </div>
  </article>
</SiteLayout>
