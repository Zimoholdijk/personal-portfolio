---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config';
---

<BaseLayout
  title={`About — ${SITE.name}`}
  description={`About ${SITE.name}: background, skills, and what I'm working on.`}
>
  <h1>About me</h1>
  <p>
    I'm Zimo, Lead Product Builder at <strong>Brthrs Agency</strong>, a Lovable
    partner agency. In under a year I went from hobbyist to building AI-powered
    products full time.
  </p>
  <p>
    I build things because I can't help myself — for clients, for my family, and
    for my community. The same energy goes into every project, whether it's an
    internal tool that turns days of work into 20 minutes, a marketplace that
    keeps perfectly good toys out of landfill, or a journaling app to help new
    mothers through post-partum. This site is built with that same energy.
  </p>
  <h2>What I do</h2>
  <p class="muted">
    Agentic AI workflows, RAG and semantic search, full-stack product
    development, and multi-sided marketplaces — taking ideas from problem to
    shipped product end to end.
  </p>
  <h2>Now</h2>
  <p class="muted">
    Leading product builds at Brthrs Agency and shipping AI tools for clients,
    family, and community.
  </p>
</BaseLayout>
