---
import { SITE } from '../config';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  // 'website' for pages, 'article' for blog posts if you add them later.
  ogType?: string;
  // Optional extra JSON-LD for a specific page.
  schema?: object;
}

const {
  title,
  description = SITE.description,
  ogImage = SITE.ogImage,
  ogType = 'website',
  schema,
} = Astro.props;

// Base-aware URL helper: works at the domain root AND under a subpath
// (e.g. username.github.io/repo-name). BASE_URL comes from `base` in astro.config.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path: string) => `${base}${path}`;

// Canonical URL — built from astro.config `site`, prevents duplicate-content issues.
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(url(ogImage), Astro.site);

// JSON-LD Person schema: tells Google who you are and links your profiles.
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.name,
  url: Astro.site?.toString(),
  email: `mailto:${SITE.email}`,
  jobTitle: SITE.tagline,
  sameAs: Object.values(SITE.socials).filter(Boolean),
};
---

<!doctype html>
<html lang={SITE.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="author" content={SITE.name} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph (link previews: Google, LinkedIn, Slack, iMessage…) -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content={SITE.name} />

    <!-- Twitter / X cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />
    <link rel="sitemap" href={url('/sitemap-index.xml')} />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
  </head>
  <body>
    <header class="site-header">
      <nav aria-label="Main navigation">
        <a class="brand" href={url('/')}>{SITE.name}</a>
        <div class="links">
          <a href={url('/about/')}>About</a>
          <a href={url('/projects/')}>Projects</a>
          <a href={url('/contact/')}>Contact</a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>© {new Date().getFullYear()} {SITE.name}</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0f1115;
    --surface: #181b22;
    --text: #e8eaed;
    --muted: #9aa0a6;
    --accent: #7aa2f7;
    --radius: 12px;
    --max-width: 44rem;
  }
  @media (prefers-color-scheme: light) {
    :root {
      --bg: #ffffff;
      --surface: #f4f5f7;
      --text: #1a1c20;
      --muted: #5f6368;
      --accent: #2456d6;
    }
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
  }
  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }
  h1, h2, h3 { line-height: 1.2; letter-spacing: -0.01em; }
  h1 { font-size: 2.25rem; }

  .site-header nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .brand { font-weight: 700; color: var(--text); }
  .links { display: flex; gap: 1.25rem; }
  .links a { color: var(--muted); }
  .links a:hover { color: var(--text); text-decoration: none; }

  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .site-footer {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
    color: var(--muted);
    font-size: 0.875rem;
    border-top: 1px solid color-mix(in srgb, var(--muted) 25%, transparent);
  }

  .card {
    background: var(--surface);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
  }
  .card h3 { margin: 0 0 0.4rem; }
  .card p { margin: 0 0 0.6rem; color: var(--muted); }
  .tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .tags span {
    font-size: 0.75rem;
    padding: 0.15rem 0.6rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    color: var(--accent);
  }
  .muted { color: var(--muted); }
</style>
