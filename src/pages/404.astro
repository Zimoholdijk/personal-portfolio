---
import SiteLayout from '../layouts/SiteLayout.astro';
import { SITE } from '../config';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<SiteLayout title={`Page not found · ${SITE.name}`} description="This page does not exist.">
  <section class="section endcta pagetop">
    <div class="wrap">
      <span class="lbl">Error 404</span>
      <h2>Not <span class="it">found.</span></h2>
      <div class="row">
        <a class="cta" href={`${base}/`}>Back home →</a>
        <a class="ghost" href={`${base}/projects/`}>See the projects</a>
      </div>
    </div>
  </section>
</SiteLayout>
