---
import SiteLayout from '../layouts/SiteLayout.astro';
import { SITE } from '../config';
import { projects } from '../data/projects';
import { toWorkRows } from '../lib/work';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const projectsUrl = `${base}/projects/`;

const firstName = SITE.name.split(' ')[0];
const rows = toWorkRows(projects, base);
const shipped = String(projects.length).padStart(2, '0');
---

<SiteLayout title={`${SITE.name} · ${SITE.tagline}`} description={SITE.description}>
  <header class="hero" id="top">
    <div class="wrap">
      <span class="lbl reveal"><i></i> Available for new builds, 2026</span>
      <h1 class="reveal" data-d="1">AI Products<br />for clients, family <span class="it">&amp; community.</span></h1>
      <div class="hero__sub reveal" data-d="2">
        <p>
          I'm {firstName}, <b>Lead Product Builder at Brthrs Agency</b>, where I
          build AI-powered products full time. Below is a selection of the things
          I've made and the problems they were built to solve.
        </p>
        <div class="hero__stats">
          <div><b>{shipped}</b><span>Shipped</span></div>
          <div><b>03</b><span>Audiences</span></div>
        </div>
      </div>
    </div>
  </header>

  <div class="marq" aria-hidden="true">
    <div class="marq__t">
      <span>AI Products</span><i>✦</i><span class="it">for clients</span><i>✦</i><span>End to end</span><i>✦</i><span class="it">for family</span><i>✦</i><span>Built with care</span><i>✦</i><span class="it">for community</span><i>✦</i>
      <span>AI Products</span><i>✦</i><span class="it">for clients</span><i>✦</i><span>End to end</span><i>✦</i><span class="it">for family</span><i>✦</i><span>Built with care</span><i>✦</i><span class="it">for community</span><i>✦</i>
    </div>
  </div>

  <section class="section" id="work">
    <div class="wrap">
      <div class="shead reveal"><h2>Selected <span class="it">work</span></h2><span class="lbl">{shipped} projects</span></div>
      <div class="cases">
        {rows.map((p) => (
          <a class="case reveal" href={p.href} style={`--c:${p.color};`}>
            <span class="case__no">{p.no}</span>
            <span class="case__name">{p.name}</span>
            <span class="case__desc">{p.blurb}</span>
            <span class="case__meta"><span class="case__thumb"></span><span class="tag">{p.audience}</span></span>
          </a>
        ))}
      </div>
      <p class="reveal" style="margin-top:clamp(28px,4vw,44px);"><a class="ghost" href={projectsUrl}>See all projects →</a></p>
    </div>
  </section>

  <section class="section" id="services" style="padding-top:0;">
    <div class="wrap">
      <div class="shead reveal"><h2>What I <span class="it">do</span></h2><span class="lbl">Capabilities</span></div>
      <div class="svcs">
        <div class="svc reveal"><span class="no">01</span><h3>AI Product Design</h3><p>I help turn a rough idea into a clear, usable product with AI at its core.</p></div>
        <div class="svc reveal" data-d="1"><span class="no">02</span><h3>End-to-end Delivery</h3><p>I stay with a product from the first concept through to a version that's live and in people's hands.</p></div>
        <div class="svc reveal" data-d="2"><span class="no">03</span><h3>Rapid Prototyping</h3><p>I can get a working prototype in front of you within days, so you can try the idea before committing to it.</p></div>
        <div class="svc reveal" data-d="3"><span class="no">04</span><h3>Ship &amp; Iterate</h3><p>Launching is only the beginning, so I keep measuring, learning, and improving the product after it goes live.</p></div>
      </div>
    </div>
  </section>

  <section class="section about" id="about" style="padding-top:0;">
    <div class="wrap">
      <p class="statement reveal">I take AI-powered products from <span class="it">idea</span> to something people can use.</p>
      <div class="about__row reveal" data-d="1">
        <span><b>Clients</b>products for the people I work with</span>
        <span><b>Family</b>products made for the people I love</span>
        <span><b>Community</b>products that give back</span>
      </div>
    </div>
  </section>

  <section class="section endcta" id="contact">
    <div class="wrap">
      <span class="lbl reveal">Got a problem worth building?</span>
      <h2 class="reveal" data-d="1"><a href={`mailto:${SITE.email}`}>Let's <span class="it">build.</span></a></h2>
      <div class="row reveal" data-d="2">
        <a class="cta" href={`mailto:${SITE.email}`}>{SITE.email} →</a>
        <a class="ghost" href="#top">Back to top</a>
      </div>
    </div>
  </section>
</SiteLayout>
